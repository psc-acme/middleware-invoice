{
    "name": "psc-acme/middleware-invoice",
    "description": "Package middleware-invoice for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\MiddlewareInvoice\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "illuminate/support": "^11.0",
        "symfony/console": "^7.0",
        "symfony/mailer": "^7.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.0",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}